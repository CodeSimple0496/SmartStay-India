rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the current user is a partner
    function isPartner() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPartner == true;
    }

    // Properties: Public can read, only Partners can write
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if request.auth != null && isPartner();
    }
    
    // Reviews: Public can read, authenticated users can write
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // User profile: ONLY the user can see their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Bookings: Total Isolation — Only the owner can see their booking
    match /bookings/{bookingId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
      );
      allow create: if request.auth != null;
    }

    // Inquiries: Secure communication
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, delete: if request.auth != null && isPartner();
    }
  }
}
